# =====================================================
# RayGumo API - Environment Variables Example
# Copy this file to .env.local for local development
# =====================================================
# This is an MVP (Game Content API: Quiz + True or False). No secrets
# are required to run the project - every variable below is optional
# and has a safe default if omitted.

# API metadata (shown by the landing page and used in package metadata)
NEXT_PUBLIC_API_NAME=RayGumo API
API_VERSION=1.0.0

# Node environment (set automatically by Vercel/Next.js in most cases)
NODE_ENV=development
